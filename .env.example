# DeepSeek API Key (必需)
DEEPSEEK_API_KEY=your_api_key_here

# DeepSeek API 端点 (可选，默认使用官方端点)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型名称 (可选)
DEEPSEEK_MODEL=deepseek-v4-flash

# 数据库路径 (可选，默认为项目根目录 cyber_memory.db)
DB_PATH=cyber_memory.db

# 日志配置
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Flask Web 服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5010
FLASK_DEBUG=False
# Flask 会话密钥（必需，生成方式：python -c "import secrets; print(secrets.token_hex(32))"）
FLASK_SECRET_KEY=change-this-to-a-random-secret-key

# LLM 参数
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60

# Playwright (可选)
PLAYWRIGHT_INSTALLED=False
BROWSER_HEADLESS=True

# CORS 配置（允许的来源域名，逗号分隔，Docker 部署时设为容器地址）
CORS_ORIGINS=http://localhost:5010,http://127.0.0.1:5010
